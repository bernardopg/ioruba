pkgname=ioruba
pkgver=${IORUBA_PKGVER:?IORUBA_PKGVER is required}
pkgrel=${IORUBA_PKGREL:-1}
pkgdesc='Tactile Linux audio mixer for Arduino Nano, powered by a Haskell runtime'
arch=('x86_64')
url='https://github.com/bernardopg/ioruba'
license=('MIT')
depends=('glibc' 'gmp')
backup=('etc/ioruba/ioruba.yaml')
options=('!debug')
source=(
  'ioruba'
  'test-serial'
  'ioruba.desktop'
  'ioruba.png'
  'ioruba.yaml'
  'nano-3knobs.yaml'
  'example.yaml'
  'ioruba-nano-3knobs.ino'
  'ioruba-nano-3knobs.ino.hex'
  'ioruba-nano-3knobs.ino.with_bootloader.hex'
  'README.md'
  'CHANGELOG.md'
  'PROJECT_SUMMARY.md'
  'LICENSE'
)
sha256sums=(
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
)

package() {
  install -Dm755 "${srcdir}/ioruba" "${pkgdir}/usr/bin/ioruba"
  install -Dm755 "${srcdir}/test-serial" "${pkgdir}/usr/bin/test-serial"

  install -Dm644 "${srcdir}/ioruba.yaml" "${pkgdir}/etc/ioruba/ioruba.yaml"
  install -Dm644 "${srcdir}/nano-3knobs.yaml" "${pkgdir}/usr/share/ioruba/config/nano-3knobs.yaml"
  install -Dm644 "${srcdir}/example.yaml" "${pkgdir}/usr/share/ioruba/config/example.yaml"

  install -Dm644 "${srcdir}/ioruba-nano-3knobs.ino" "${pkgdir}/usr/share/ioruba/firmware/ioruba-nano-3knobs.ino"
  install -Dm644 "${srcdir}/ioruba-nano-3knobs.ino.hex" "${pkgdir}/usr/share/ioruba/firmware/ioruba-nano-3knobs.ino.hex"
  install -Dm644 "${srcdir}/ioruba-nano-3knobs.ino.with_bootloader.hex" "${pkgdir}/usr/share/ioruba/firmware/ioruba-nano-3knobs.ino.with_bootloader.hex"

  install -Dm644 "${srcdir}/ioruba.desktop" "${pkgdir}/usr/share/applications/ioruba.desktop"
  install -Dm644 "${srcdir}/ioruba.png" "${pkgdir}/usr/share/icons/hicolor/128x128/apps/ioruba.png"

  install -Dm644 "${srcdir}/README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 "${srcdir}/CHANGELOG.md" "${pkgdir}/usr/share/doc/${pkgname}/CHANGELOG.md"
  install -Dm644 "${srcdir}/PROJECT_SUMMARY.md" "${pkgdir}/usr/share/doc/${pkgname}/PROJECT_SUMMARY.md"
  install -Dm644 "${srcdir}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
