{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ioruba",
  "version": "0.6.2",
  "identifier": "io.ioruba.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "title": "Ioruba",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Tactile audio mixer for Arduino-based Linux control",
    "homepage": "https://github.com/bernardopg/ioruba",
    "license": "MIT",
    "category": "Music",
    "copyright": "Bernardo Gomes",
    "linux": {
      "deb": {
        "depends": [
          "libgtk-3-0",
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1 | libappindicator3-1"
        ]
      }
    }
  }
}
