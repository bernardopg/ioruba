{
  "name": "@ioruba/desktop",
  "version": "0.6.7",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420",
    "desktop:watch": "tauri dev",
    "build": "tsc --project tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "tauri": "tauri",
    "icons:generate": "npm exec tauri -- icon \"$PWD/src-tauri/icons/app-icon.svg\" -o \"$PWD/src-tauri/icons\""
  },
  "dependencies": {
    "@fontsource/instrument-sans": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.8",
    "@ioruba/shared": "file:../../packages/shared",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tauri-apps/api": "^2.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.4.0",
    "tauri-plugin-serialplugin-api": "^2.22.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
